		)
		(uuid "9f7628b0-c6e2-42d3-9114-eabb95b14dab")
	)
	(text "J1 PINOUT (matches motherboard): 1=DB_EN, 2=DB_S3, 3=DB_S2, 4=DB_S1, 5=DB_S0, 6=GND, 7=ANALOG_COM, 8=+5V."
		(exclude_from_sim no)
		(at 20 235 0)
		(effects
			(font
				(size 1.3 1.3)
			)
			(justify left bottom)
		)
		(uuid "aefa3b39-c6f9-49bd-9f2f-f6fd89f43909")
	)
	(text "Use direct cable connection: motherboard J8/J9/J10/J11 -> J1. For a future hub, keep the same 8-pin pin order."
		(exclude_from_sim no)
		(at 20 247 0)
		(effects
			(font
				(size 1.3 1.3)
			)
			(justify left bottom)
		)
		(uuid "bb190f7f-e081-48dd-aace-02a469faf6e7")
	)
	(text "J2-J17: one 2-pin connection per PZT. Pin 1 is the individually multiplexed PZT+; pin 2 is the shared analog return/GND."
		(exclude_from_sim no)
		(at 20 241 0)
		(effects
			(font
				(size 1.3 1.3)
			)
			(justify left bottom)
		)
		(uuid "bf4ea820-bdb8-45a1-a940-6a4b7d5c9b5a")
	)
	(text "Directly compatible with one 8-pin motherboard sensor jack. J1 pin order matches the uploaded motherboard."
		(exclude_from_sim no)
		(at 20 21 0)
		(effects
			(font
				(size 1.3 1.3)
			)
			(justify left bottom)
		)
		(uuid "d6bb0c12-6cfd-40a3-b82b-fc4a42c9824f")
	)
